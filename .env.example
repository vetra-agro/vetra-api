# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT (gerado pelo Supabase Auth, mas você pode customizar) ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── Throttle (rate limit) ─────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── CORS ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3001,https://vetra.agr.br
